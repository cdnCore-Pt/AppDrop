{
    "translations": {
        "Actions": "\u0639\u0645\u0644\u06cc\u0627\u062a",
        "Administrators always have full access. Add groups or individual users below to grant them upload permission.": "\u0645\u062f\u06cc\u0631\u0627\u0646 \u0647\u0645\u06cc\u0634\u0647 \u062f\u0633\u062a\u0631\u0633\u06cc \u06a9\u0627\u0645\u0644 \u062f\u0627\u0631\u0646\u062f. \u06af\u0631\u0648\u0647\u200c\u0647\u0627 \u06cc\u0627 \u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0645\u0648\u0631\u062f \u0646\u0638\u0631 \u0631\u0627 \u062f\u0631 \u0632\u06cc\u0631 \u0627\u0636\u0627\u0641\u0647 \u06a9\u0646\u06cc\u062f \u062a\u0627 \u0645\u062c\u0648\u0632 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc \u0628\u0647 \u0622\u0646\u200c\u0647\u0627 \u0627\u0639\u0637\u0627 \u0634\u0648\u062f.",
        "Administrators always have full access. Add groups or individual users below to grant upload permission.": "\u0645\u062f\u06cc\u0631\u0627\u0646 \u0647\u0645\u06cc\u0634\u0647 \u062f\u0633\u062a\u0631\u0633\u06cc \u06a9\u0627\u0645\u0644 \u062f\u0627\u0631\u0646\u062f. \u06af\u0631\u0648\u0647\u200c\u0647\u0627 \u06cc\u0627 \u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0645\u0648\u0631\u062f \u0646\u0638\u0631 \u0631\u0627 \u062f\u0631 \u0632\u06cc\u0631 \u0627\u0636\u0627\u0641\u0647 \u06a9\u0646\u06cc\u062f \u062a\u0627 \u0645\u062c\u0648\u0632 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc \u0627\u0639\u0637\u0627 \u0634\u0648\u062f.",
        "Allowed Groups": "\u06af\u0631\u0648\u0647\u200c\u0647\u0627\u06cc \u0645\u062c\u0627\u0632",
        "Allowed Users": "\u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0645\u062c\u0627\u0632",
        "App Display Name": "\u0646\u0627\u0645 \u0646\u0645\u0627\u06cc\u0634\u06cc \u0628\u0631\u0646\u0627\u0645\u0647",
        "App ID": "\u0634\u0646\u0627\u0633\u0647 \u0628\u0631\u0646\u0627\u0645\u0647",
        "AppDrop": "AppDrop",
        "Apps": "\u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627",
        "App Skeleton Generator": "\u0633\u0627\u0632\u0646\u062f\u0647 \u0642\u0627\u0644\u0628 \u0628\u0631\u0646\u0627\u0645\u0647",
        "Author": "\u0646\u0648\u06cc\u0633\u0646\u062f\u0647",
        "Auto-enable app after install": "\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u062e\u0648\u062f\u06a9\u0627\u0631 \u0628\u0631\u0646\u0627\u0645\u0647 \u067e\u0633 \u0627\u0632 \u0646\u0635\u0628",
        "Auto-enable apps": "\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u062e\u0648\u062f\u06a9\u0627\u0631 \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627",
        "auto-generated": "\u062a\u0648\u0644\u06cc\u062f\u0634\u062f\u0647 \u062e\u0648\u062f\u06a9\u0627\u0631",
        "Automatically enable apps after upload (users can override per upload)": "\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u062e\u0648\u062f\u06a9\u0627\u0631 \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627 \u067e\u0633 \u0627\u0632 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc (\u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0645\u06cc\u200c\u062a\u0648\u0627\u0646\u0646\u062f \u0628\u0631\u0627\u06cc \u0647\u0631 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc \u062a\u063a\u06cc\u06cc\u0631 \u062f\u0647\u0646\u062f)",
        "Backup Date": "\u062a\u0627\u0631\u06cc\u062e \u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u200c\u06af\u06cc\u0631\u06cc",
        "Backups": "\u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u200c\u0647\u0627",
        "Between 1 and 512 MB. Also limited by PHP upload_max_filesize.": "\u0628\u06cc\u0646 \u06f1 \u062a\u0627 \u06f5\u06f1\u06f2 \u0645\u06af\u0627\u0628\u0627\u06cc\u062a. \u0647\u0645\u0686\u0646\u06cc\u0646 \u062a\u0648\u0633\u0637 upload_max_filesize \u062f\u0631 PHP \u0645\u062d\u062f\u0648\u062f \u0645\u06cc\u200c\u0634\u0648\u062f.",
        "Configure upload limits and default behavior for the AppDrop.": "\u067e\u06cc\u06a9\u0631\u0628\u0646\u062f\u06cc \u0645\u062d\u062f\u0648\u062f\u06cc\u062a\u200c\u0647\u0627\u06cc \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc \u0648 \u0631\u0641\u062a\u0627\u0631 \u067e\u06cc\u0634\u200c\u0641\u0631\u0636 \u0628\u0631\u0627\u06cc AppDrop.",
        "Create a ready-to-use Nextcloud app template with all required files and folder structure. Fill in the details below and download a .zip file you can immediately install.": "\u06cc\u06a9 \u0642\u0627\u0644\u0628 \u0622\u0645\u0627\u062f\u0647 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0628\u0631\u0646\u0627\u0645\u0647 Nextcloud \u0628\u0627 \u062a\u0645\u0627\u0645 \u0641\u0627\u06cc\u0644\u200c\u0647\u0627 \u0648 \u0633\u0627\u062e\u062a\u0627\u0631 \u067e\u0648\u0634\u0647 \u0645\u0648\u0631\u062f \u0646\u06cc\u0627\u0632 \u0628\u0633\u0627\u0632\u06cc\u062f. \u062c\u0632\u0626\u06cc\u0627\u062a \u0632\u06cc\u0631 \u0631\u0627 \u067e\u0631 \u06a9\u0646\u06cc\u062f \u0648 \u06cc\u06a9 \u0641\u0627\u06cc\u0644 zip. \u062f\u0627\u0646\u0644\u0648\u062f \u06a9\u0646\u06cc\u062f \u06a9\u0647 \u0628\u0644\u0627\u0641\u0627\u0635\u0644\u0647 \u0642\u0627\u0628\u0644 \u0646\u0635\u0628 \u0627\u0633\u062a.",
        "Date": "\u062a\u0627\u0631\u06cc\u062e",
        "Description": "\u062a\u0648\u0636\u06cc\u062d\u0627\u062a",
        "Directory": "\u067e\u0648\u0634\u0647",
        "Drag & drop .zip files here or click to browse": "\u0641\u0627\u06cc\u0644\u200c\u0647\u0627\u06cc zip. \u0631\u0627 \u0627\u06cc\u0646\u062c\u0627 \u0628\u06a9\u0634\u06cc\u062f \u0648 \u0631\u0647\u0627 \u06a9\u0646\u06cc\u062f \u06cc\u0627 \u0628\u0631\u0627\u06cc \u0645\u0631\u0648\u0631 \u06a9\u0644\u06cc\u06a9 \u06a9\u0646\u06cc\u062f",
        "e.g. My Cool App": "\u0645\u062b\u0644\u0627\u064b \u0628\u0631\u0646\u0627\u0645\u0647 \u062c\u0630\u0627\u0628 \u0645\u0646",
        "File": "\u0641\u0627\u06cc\u0644",
        "General": "\u0639\u0645\u0648\u0645\u06cc",
        "Generated file structure": "\u0633\u0627\u062e\u062a\u0627\u0631 \u0641\u0627\u06cc\u0644 \u062a\u0648\u0644\u06cc\u062f\u0634\u062f\u0647",
        "Generate & Download": "\u062a\u0648\u0644\u06cc\u062f \u0648 \u062f\u0627\u0646\u0644\u0648\u062f",
        "Generator": "\u0633\u0627\u0632\u0646\u062f\u0647",
        "History": "\u062a\u0627\u0631\u06cc\u062e\u0686\u0647",
        "Install / Update": "\u0646\u0635\u0628 / \u0628\u0647\u200c\u0631\u0648\u0632\u0631\u0633\u0627\u0646\u06cc",
        "Loading...": "\u062f\u0631 \u062d\u0627\u0644 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc...",
        "Manage custom apps installed via AppDrop.": "\u0645\u062f\u06cc\u0631\u06cc\u062a \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627\u06cc \u0633\u0641\u0627\u0631\u0634\u06cc \u0646\u0635\u0628\u200c\u0634\u062f\u0647 \u0627\u0632 \u0637\u0631\u06cc\u0642 AppDrop.",
        "Maximum upload size": "\u062d\u062f\u0627\u06a9\u062b\u0631 \u062d\u062c\u0645 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc",
        "Max %s MB per file. Must contain appinfo/info.xml. Existing apps are automatically backed up before update.": "\u062d\u062f\u0627\u06a9\u062b\u0631 %s \u0645\u06af\u0627\u0628\u0627\u06cc\u062a \u0628\u0631\u0627\u06cc \u0647\u0631 \u0641\u0627\u06cc\u0644. \u0628\u0627\u06cc\u062f \u0634\u0627\u0645\u0644 appinfo/info.xml \u0628\u0627\u0634\u062f. \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627\u06cc \u0645\u0648\u062c\u0648\u062f \u0642\u0628\u0644 \u0627\u0632 \u0628\u0647\u200c\u0631\u0648\u0632\u0631\u0633\u0627\u0646\u06cc \u0628\u0647\u200c\u0635\u0648\u0631\u062a \u062e\u0648\u062f\u06a9\u0627\u0631 \u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u200c\u06af\u06cc\u0631\u06cc \u0645\u06cc\u200c\u0634\u0648\u0646\u062f.",
        "Name": "\u0646\u0627\u0645",
        "Next": "\u0628\u0639\u062f\u06cc",
        "No groups added yet.": "\u0647\u0646\u0648\u0632 \u06af\u0631\u0648\u0647\u06cc \u0627\u0636\u0627\u0641\u0647 \u0646\u0634\u062f\u0647 \u0627\u0633\u062a.",
        "No users added yet.": "\u0647\u0646\u0648\u0632 \u06a9\u0627\u0631\u0628\u0631\u06cc \u0627\u0636\u0627\u0641\u0647 \u0646\u0634\u062f\u0647 \u0627\u0633\u062a.",
        "Open App": "\u0628\u0627\u0632 \u06a9\u0631\u062f\u0646 \u0628\u0631\u0646\u0627\u0645\u0647",
        "Open AppDrop": "\u0628\u0627\u0632 \u06a9\u0631\u062f\u0646 AppDrop",
        "PascalCase PHP namespace for your app classes (e.g. MyCoolApp). Auto-generated from the display name.": "\u0641\u0636\u0627\u06cc \u0646\u0627\u0645 PHP \u0628\u0647 \u0635\u0648\u0631\u062a PascalCase \u0628\u0631\u0627\u06cc \u06a9\u0644\u0627\u0633\u200c\u0647\u0627\u06cc \u0628\u0631\u0646\u0627\u0645\u0647 \u0634\u0645\u0627 (\u0645\u062b\u0644\u0627\u064b MyCoolApp). \u0628\u0647\u200c\u0635\u0648\u0631\u062a \u062e\u0648\u062f\u06a9\u0627\u0631 \u0627\u0632 \u0646\u0627\u0645 \u0646\u0645\u0627\u06cc\u0634\u06cc \u062a\u0648\u0644\u06cc\u062f \u0645\u06cc\u200c\u0634\u0648\u062f.",
        "Permissions": "\u0645\u062c\u0648\u0632\u0647\u0627",
        "PHP Namespace": "\u0641\u0636\u0627\u06cc \u0646\u0627\u0645 PHP",
        "Previous": "\u0642\u0628\u0644\u06cc",
        "Refresh": "\u0628\u0627\u0632\u0622\u0648\u0631\u06cc",
        "Remove": "\u062d\u0630\u0641",
        "Result": "\u0646\u062a\u06cc\u062c\u0647",
        "Save": "\u0630\u062e\u06cc\u0631\u0647",
        "Saved": "\u0630\u062e\u06cc\u0631\u0647 \u0634\u062f",
        "Search groups...": "\u062c\u0633\u062a\u062c\u0648\u06cc \u06af\u0631\u0648\u0647\u200c\u0647\u0627...",
        "Search users...": "\u062c\u0633\u062a\u062c\u0648\u06cc \u06a9\u0627\u0631\u0628\u0631\u0627\u0646...",
        "Settings": "\u062a\u0646\u0638\u06cc\u0645\u0627\u062a",
        "Short description of your app": "\u062a\u0648\u0636\u06cc\u062d \u06a9\u0648\u062a\u0627\u0647 \u0628\u0631\u0646\u0627\u0645\u0647 \u0634\u0645\u0627",
        "Status": "\u0648\u0636\u0639\u06cc\u062a",
        "The human-readable name shown in the Nextcloud app list.": "\u0646\u0627\u0645 \u0642\u0627\u0628\u0644 \u062e\u0648\u0627\u0646\u062f\u0646 \u06a9\u0647 \u062f\u0631 \u0641\u0647\u0631\u0633\u062a \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627\u06cc Nextcloud \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0645\u06cc\u200c\u0634\u0648\u062f.",
        "Unique identifier (lowercase, digits, underscores). Used as the directory name. Auto-generated from the display name.": "\u0634\u0646\u0627\u0633\u0647 \u06cc\u06a9\u062a\u0627 (\u062d\u0631\u0648\u0641 \u06a9\u0648\u0686\u06a9\u060c \u0627\u0631\u0642\u0627\u0645\u060c \u0632\u06cc\u0631\u062e\u0637). \u0628\u0647 \u0639\u0646\u0648\u0627\u0646 \u0646\u0627\u0645 \u067e\u0648\u0634\u0647 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0645\u06cc\u200c\u0634\u0648\u062f. \u0628\u0647\u200c\u0635\u0648\u0631\u062a \u062e\u0648\u062f\u06a9\u0627\u0631 \u0627\u0632 \u0646\u0627\u0645 \u0646\u0645\u0627\u06cc\u0634\u06cc \u062a\u0648\u0644\u06cc\u062f \u0645\u06cc\u200c\u0634\u0648\u062f.",
        "Upload": "\u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc",
        "Upload history for all app installations performed via this tool.": "\u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc \u0628\u0631\u0627\u06cc \u062a\u0645\u0627\u0645 \u0646\u0635\u0628\u200c\u0647\u0627\u06cc \u0628\u0631\u0646\u0627\u0645\u0647 \u0627\u0646\u062c\u0627\u0645\u200c\u0634\u062f\u0647 \u0627\u0632 \u0637\u0631\u06cc\u0642 \u0627\u06cc\u0646 \u0627\u0628\u0632\u0627\u0631.",
        "Upload Nextcloud app packages (.zip) to install or update. The app ID and version are detected automatically from info.xml.": "\u0628\u0633\u062a\u0647\u200c\u0647\u0627\u06cc \u0628\u0631\u0646\u0627\u0645\u0647 Nextcloud (\u0641\u0627\u06cc\u0644 zip.) \u0631\u0627 \u0628\u0631\u0627\u06cc \u0646\u0635\u0628 \u06cc\u0627 \u0628\u0647\u200c\u0631\u0648\u0632\u0631\u0633\u0627\u0646\u06cc \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc \u06a9\u0646\u06cc\u062f. \u0634\u0646\u0627\u0633\u0647 \u0648 \u0646\u0633\u062e\u0647 \u0628\u0631\u0646\u0627\u0645\u0647 \u0628\u0647\u200c\u0635\u0648\u0631\u062a \u062e\u0648\u062f\u06a9\u0627\u0631 \u0627\u0632 info.xml \u0634\u0646\u0627\u0633\u0627\u06cc\u06cc \u0645\u06cc\u200c\u0634\u0648\u062f.",
        "User": "\u06a9\u0627\u0631\u0628\u0631",
        "Use the full app interface for uploading, managing apps, viewing history, and generating app skeletons.": "\u0627\u0632 \u0631\u0627\u0628\u0637 \u06a9\u0627\u0645\u0644 \u0628\u0631\u0646\u0627\u0645\u0647 \u0628\u0631\u0627\u06cc \u0628\u0627\u0631\u06af\u0630\u0627\u0631\u06cc\u060c \u0645\u062f\u06cc\u0631\u06cc\u062a \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627\u060c \u0645\u0634\u0627\u0647\u062f\u0647 \u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u0648 \u062a\u0648\u0644\u06cc\u062f \u0642\u0627\u0644\u0628 \u0628\u0631\u0646\u0627\u0645\u0647 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u06a9\u0646\u06cc\u062f.",
        "Version": "\u0646\u0633\u062e\u0647",
        "View and manage backups created during app updates.": "\u0645\u0634\u0627\u0647\u062f\u0647 \u0648 \u0645\u062f\u06cc\u0631\u06cc\u062a \u067e\u0634\u062a\u06cc\u0628\u0627\u0646\u200c\u0647\u0627\u06cc \u0627\u06cc\u062c\u0627\u062f\u0634\u062f\u0647 \u062f\u0631 \u0647\u0646\u06af\u0627\u0645 \u0628\u0647\u200c\u0631\u0648\u0632\u0631\u0633\u0627\u0646\u06cc \u0628\u0631\u0646\u0627\u0645\u0647\u200c\u0647\u0627.",
        "Your Name": "\u0646\u0627\u0645 \u0634\u0645\u0627"
    },
    "plurals": {}
}
