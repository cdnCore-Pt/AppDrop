<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>appdrop</id>
    <name>AppDrop</name>
    <summary>Securely upload, validate and install custom Nextcloud app packages via the web UI</summary>
    <description><![CDATA[
        AppDrop allows Nextcloud administrators to upload a .zip package of a
        custom Nextcloud app directly from the web UI, validate it (Zip Slip protection, MIME check,
        appinfo/info.xml verification), extract it safely into a writable apps path, set correct
        permissions, and enable it — all without SSH access.
    ]]></description>
    <version>1.3.2</version>
    <licence>agpl-3.0-or-later</licence>
    <author>Mehran Pourvahab</author>
    <author>Henrique Rodrigues</author>
    <namespace>AppDrop</namespace>
    <category>tools</category>
    <website>https://github.com/cdnCore-Pt/AppDrop</website>
    <bugs>https://github.com/cdnCore-Pt/AppDrop/issues</bugs>
    <repository type="git">https://github.com/cdnCore-Pt/AppDrop</repository>
    <screenshot>https://raw.githubusercontent.com/cdnCore-Pt/AppDrop/main/screenshots/upload.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/cdnCore-Pt/AppDrop/main/screenshots/uploaded.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/cdnCore-Pt/AppDrop/main/screenshots/apps.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/cdnCore-Pt/AppDrop/main/screenshots/generator.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/cdnCore-Pt/AppDrop/main/screenshots/history.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/cdnCore-Pt/AppDrop/main/screenshots/backups.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/cdnCore-Pt/AppDrop/main/screenshots/permissions.png</screenshot>
    <documentation>
        <admin>https://github.com/cdnCore-Pt/AppDrop#usage</admin>
    </documentation>
    <dependencies>
        <nextcloud min-version="30" max-version="32"/>
        <php min-version="8.1"/>
    </dependencies>
    <!-- Navigation is registered dynamically in Application::register()
         so it only appears for users with upload permission. -->
    <settings>
        <admin>OCA\AppDrop\Settings\AdminSettings</admin>
        <admin-section>OCA\AppDrop\Settings\AdminSection</admin-section>
    </settings>
</info>
